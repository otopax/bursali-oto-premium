$(document).ready(function(){$(".licenseExpireAlertHideButton").click(function(event){event.stopPropagation();event.preventDefault();var url=$(this).attr("data-url");if(!isNullOrEmpty(url)){$.ajax({url:url,type:"POST",success:function(data){}})}$(".licenseExpireAlert").fadeOut()});$(".redirectNotificationBtn").click(function(event){event.stopPropagation();event.preventDefault();$(".lineoutLogin").removeClass("redirect-notification-visible");$(".notification-warning-panel").fadeOut()})})