location.href=window.resolveUriForTheRelay(url)}}}function getVehicleCategoryParam(){return"&truckCategory="+$("#truckCategory").val()}function viewAllLicesePlateFilterResults(url){var keyword=$('#numberPlate').val();if(keyword!=undefined&&$.trim(keyword)!=''){if($("#numberPlateRegion").length){var vrmStateCode=$("#numberPlateRegion").find(":selected").val();if(!isNullOrEmpty(vrmStateCode)){keyword=keyword+"%2B"+vrmStateCode}}keyword=keyword.replace(/[' ']/g,'');url=url+'?keyword='+keyword+'&termType='+$('#licencePlateBtn').attr('data-term')+'&numberPlate='+keyword+'&allResults=true'+getVehicleCategoryParam();document.location.href=window.resolveUriForTheRelay(url)}}function viewInputSearch(url){var keyword=$('#numberPlate').val();if(keyword!=undefined&&$.trim(keyword)!=''){keyword=keyword.replace(/[' ']/g,'');url=url+'&keyword='+keyword;document.location.href=window.resolveUriForTheRelay(url)}}function getTruckCategory(){var truckCategory='cars';if($("section.main-nav nav ul li.cars").hasClass("active")){truckCategory='cars'}else if($("section.main-nav nav ul li.trucks").hasClass("active")){if($('.navigation a.select-trailer').parent().hasClass("active")){truckCategory='trailers'}else if($('.navigation a.select-truck').parent().hasClass("active")){truckCategory='trucks'}else{var activeContentIndex=$('.makeTrucks ul.active').index();$('.sub-nav ul.navigation li:eq('+activeContentIndex+')').addClass("active");if(activeContentIndex==0){truckCategory='trucks'}else{truckCategory='trailers'}}}return truckCategory}