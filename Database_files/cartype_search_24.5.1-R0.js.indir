NE_CODE_SEARCH||searchSection==ENGINE_CODE_SEARCH}function isKBASearch(searchType,searchSection){return searchType==KBA_SEARCH||searchSection==KBA_SEARCH}function isTypenscheinSearch(searchType,searchSection){return searchType==TYPENSCHEIN_SEARCH||searchSection==TYPENSCHEIN_SEARCH}function isVINSearch(searchType,searchSection){return searchType==VIN_SEARCH||searchSection==VIN_SEARCH}function isTypeApprovalSearch(searchType,searchSection){return searchType==TYPE_APPROVAL_SEARCH||searchSection==TYPE_APPROVAL_SEARCH}function getExtraInfoParamAndValue(searchType,searchSection,extraInfo,searchedText){var paramAndValue="";if(isTecdocSearch(searchType,searchSection)){paramAndValue=KTYP_NR_PARAM+extraInfo+"&searchedTecDoc="+extraInfo}else if(isEngineCodeSearch(searchType,searchSection)){paramAndValue="&engineCode="+extraInfo}else if(isKBASearch(searchType,searchSection)){paramAndValue="&kba="+extraInfo}else if(isTypenscheinSearch(searchType,searchSection)){paramAndValue="&typenschein="+searchedText;if(!isNullOrEmpty(extraInfo)){paramAndValue+=KTYP_NR_PARAM+extraInfo}}else if(isVINSearch(searchType,searchSection)){paramAndValue="&vin="+searchedText+"&vinSearch=true"}else if(isTypeApprovalSearch(searchType,searchSection)){paramAndValue="&typeApproval="+searchedText}return paramAndValue}function showCvoData(data,termType,searchedText){var previous=null;$.each(data.cvo2DataMap,function(keyMap,valueMap){var cvo2DataSet=valueMap;$.each(cvo2DataSet,function(key,value){var showEegImplementedCode=false;$.each(data.cvo2DataMap,function(keyMapTemp,valueMapTemp){var cvo2DataSetTemp=valueMapTemp;$.each(cvo2DataSetTemp,function(keyTemp,valueTemp){if(value.eegVarCode==valueTemp.eegVarCode&&value.externalCarId!=valueTemp.externalCarId){showEegImplementedCode=true}})});var item=value;var eegVarCode=item.eegVarCode;if(showEegImplementedCode==true){eegVarCode+=" "+item.eegImplementedCode}if(showEegImplementedCode==false&&(previous==null||previous!=null&&item.eegVarCode!=previous)||showEegImpl