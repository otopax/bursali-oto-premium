var ENGINE_CODE_SEARCH=1;var TECDOC_SEARCH=2;var KBA_SEARCH=3;var TYPE_APPROVAL_SEARCH=4;var VIN_SEARCH=5;var TYPENSCHEIN_SEARCH=10;var CARS_CATEGORY="cars";var KTYP_NR_PARAM="&ktypNr=";var ENTER_KEY_CODE=13;$(document).ready(function(){$('#numberPlate').keypress(function(e){if(e.which==ENTER_KEY_CODE){$('#licencePlateBtn')[0].click()}});$('#numberPlate').on('input blur keyup paste',function(){$(this).val(function(i,v){return v.replace(/[^a-z0-9\-]/ig,'')})});$("a#viewAllResults").click(function(event){event.preventDefault();if(!$(this).hasClass("disabled")){viewAllResults($(this).attr("data-url"))}});$("#numberPlateRegion").on("change",function(){Cookies.set('vrmStateCode',this.value,{expires:365,path:'',secure:true,sameSite:'none'})});var truckCategory=$('#truckCategory').val();var selectedTruckTab=truckCategory=='trailers'?1:0;$('.sub-nav ul.navigation li ').find('li:eq('+selectedTruckTab+')').trigger('click');$(".search-input").keyup(function(){setTimeout(highlightSearchResult,500)});$('.sortableColumn0, .sortableColumn1, .sortableColumnExtraInfo').click(function(){$(this).attr('data-order',$(this).attr('data-order')==='asc'?'desc':'asc');$(this).closest('tr').find('.active').removeClass('active');$(this).addClass('active');$(this).toggleClass('ascending descending');sortTable(this,$(this).parent().index(),"false")});$('.sortableColumn2, .sortableColumn3, .sortableColumn4, .sortableColumn5').click(function(){$(this).attr('data-order',$(this).attr('data-order')==='asc'?'desc':'asc');$(this).closest('tr').find('.active').removeClass('active');$(this).addClass('active');$(this).toggleClass('ascending descending');sortTable(this,$(this).parent().index(),"true")})});function escapeRegExp(string){return string.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')}function highlightSearchResult(){var searchedString=$(".search-input").val().replace(/\s+/g,' ');if(searchedString!=undefined&&searchedString.replace(" ","").length>1){var resultTable=$("#titledTables tbody");var searchedWords=decodeURIComponent(searchedString).split(' ');for(var j=0;j<resultTable.length;j++){for(var i=0;i<searchedWords.length;i++){var pattern=new RegExp("([>][^<]*)("+escapeRegExp(searchedWords[i])+")([^>]*[<])","gi");var newHtml=$(resultTable[j]).html().replace(pattern,'$1<span class="highlightedWord">$2</span>$3');$(resultTable[j]).html(newHtml)}}}}function sortTable(header,index,float){var $tableToSort=$(header).closest('table');var order=$(header).attr('data-order');$tableToSort.find('tr:gt(0)').sort(function(a,b){var tda=$(a).find('td:eq('+index+')').text();var tdb=$(b).find('td:eq('+index+')').text();if(float==="true"){tda=parseFloat(tda||"0");tdb=parseFloat(tdb||"0");return order==='asc'?tda-tdb>0?1:tda-tdb<0?-1:0:tda-tdb<0?1:tda-tdb>0?-1:0}return order==='asc'?tda>tdb?1:tda<tdb?-1:0:tda<tdb?1:tda>tdb?-1:0}).appendTo($tableToSort)}var xhr;function typeAsYouSearch(){var etkPattern=/^([e](\d){1,2})\*(.{0,25})\*(\d{4,6})(\*\d{0,2})?$/i;var termType=$('.search-filters li a.active').attr("data-term");var term=$('.search-input').val();if(termType!=4){search()}else{var searchValid=false;if(termType==4){searchValid=etkPattern.test(term)||term.trim().toUpperCase()=='OUTATIME'}if(searchValid){$("#search_button-holder").removeClass("inactive");$("#search-info-quick").hide();$("#search_button-holder a.button").click(function(){search()})}else{$("#search_button-holder").addClass("inactive");$("#search_button-holder a.button").unbind("click")}}}function TypeApprovalSearch(){var suggestions;var variant=VariantClass();var implCode=ImplCodeClass();var previousTypeApproval="";function VariantClass(){var selectedVariantCode;function getVariantDOM(){return $('#etkField2').find('select')}function init(){var variantDOM=getVariantDOM();variantDOM.on('change',implCode.populateImplementationCode);variantDOM.on('change',function(event){var selection=getValue();if(selection!=undefined){selectedVariantCode=selection}additionalETKFieldsHandler()})}function populateVariantCodes(){var variantCodes=[];if(suggestions!=null){for(var i=0;i<suggestions.length;i++){if(variantCodes.indexOf(suggestions[i].eegVarCode)<0){variantCodes.push(suggestions[i].eegVarCode)}}}var variantDOM=getVariantDOM();variantDOM.find('option').not('.default').remove();if(variantCodes.length>0){for(var i=0;i<variantCodes.length;i++){variantDOM.append(new Option(variantCodes[i],variantCodes[i],false,variantCodes.length==1||variantCodes[i]==selectedVariantCode))}variantDOM.prop("disabled",false);implCode.populateImplementationCode()}else{depopulateVariantCode()}}function depopulateVariantCode(){var variantDOM=getVariantDOM();if(variantDOM.prop("disabled")!=true){variantDOM.prop("disabled",true);variantDOM.find('option').not('.default').remove()}implCode.depopulateImplementationCode()}function getValue(){return getVariantDOM().find('option:selected').val()}return{"getVariantDOM":getVariantDOM,"init":init,"populateVariantCodes":populateVariantCodes,"depopulateVariantCode":depopulateVariantCode,"getValue":getValue}}function ImplCodeClass(){var selectedImplementationCode;function getImplDOM(){return $('#etkField3').find('select')}function init(){var implDOM=getImplDOM();implDOM.on('change',function(event){var selection=implDOM.find('option:selected').val();if(selection!=undefined&&selection!='none'){selectedImplementationCode=selection}additionalETKFieldsHandler()})}function populateImplementationCode(){depopulateImplementationCode();var selectedVariant=variant.getValue();if(selectedVariant!=undefined&&selectedVariant!='none'){var implCodes=[];for(var i=0;i<suggestions.length;i++){if(suggestions[i].eegVarCode==selectedVariant&&implCodes.indexOf(suggestions[i].eegImplementedCode)<0){implCodes.push(suggestions[i].eegImplementedCode)}}var implDOM=getImplDOM();if(implCodes.length>0){for(var i=0;i<implCodes.length;i++){implDOM.append(new Option(implCodes[i],implCodes[i],false,implCodes.length==1))}implDOM.prop("disabled",false)}else{depopulateImplementationCode()}}}function depopulateImplementa