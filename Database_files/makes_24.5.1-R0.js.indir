$(document).ready(function(){prepFavoritesList();var docHeight=$(document).height();if($('.errorMessage').length>0){$('.errorMessage').delay(5000).fadeOut("slow")}if($('#goToOvervieBtn').length>0&&$('#typeToTest').length>0){$('#goToOvervieBtn').on('click',function(){var typeId=$('#typeToTest').val();var url=$('#goToOvervieBtn').attr('data-url');document.location.href=window.resolveUriForTheRelay(url+'?typeId=t_'+typeId)})}$('.select-make, .select-moto').on('click',function(){if($(this).parent("li").hasClass('active')){}else{$(this).closest("nav.lineout").find("a.popover.active").click()}});$('.select-recent-car').on('click',function(){var url=$(this).attr('data-url');var urlModelDetails=$(this).attr('data-url-modelDetail');var urlWoDetails=$(this).attr('data-url-woDetail');carsHistory(url,urlModelDetails,urlWoDetails);$('.overlay:not(#overlay-recent)').trigger("click");filterPanel=$('#select-recent-car');if($(this).parent("li").hasClass('active')){$(this).removeClass('active');$(this).parent("li").removeClass('active');$(this).closest("ul").find("li").first().addClass('active');filterPanel.css({opacity:0,display:'none'});$('#overlay-recent').remove()}else{$(this).closest("ul").find("li").removeClass('active');$(this).parent("li").addClass('active');$(this).addClass('active');filterPanel.css({display:'block',opacity:1});$('<div id="overlay-recent" class="overlay"></div>').appendTo('body');$('#overlay-recent').click(function(event){event.stopPropagation();$('#select-recent-car').css({opacity:0,display:'none'});if($('.select-recent-car').parent("li").hasClass('active')){$('.select-recent-car').trigger('click')}$('#overlay-recent').remove();$('.select-recent-car').removeClass('active')});if($('html').hasClass('detail')){$('#overlay-recent').height(docHeight-55);$('#overlay-recent').css({top:55})}else{$('#overlay-recent').height(docHeight-100);$('#overlay-recent').css({top:100})}}});$('.list-tile-view').click(function(event,save){switchToListMakeLogos();$("ul.view-type li").removeClass("active");$(this).parent().addClass("active");$("#favoritesSection").show();$("ul#makes li span.fav").show();$("#makesSection .view").removeClass("tiles").addClass("list");$("ul#makes li").removeClass("tile");calcTiles();calcList();if(save!=false){saveViewTypeToPreferences($(this).attr('class'),$(this).attr('activePage'),$(this).attr('data-save-url'))}});$('.tile-view').click(function(event,save){switchToBigMakeLogos();$("ul.view-type li").removeClass("active");$(this).parent().addClass("active");if($(".demoUser")[0]){$("#favoritesSection").show()}else{$("#favoritesSection").hide()}$("ul#makes li span.fav").hide();$("#makesSection .view").removeClass("list").addClass("tiles");$("ul#makes li").addClass("tile");calcTiles();if(save!=false){saveViewTypeToPreferences($(this).attr('class'),$(this).attr('activePage'),$(this).attr('data-save-url'))}});$('.list-view').click(function(event,save){switchToListMakeLogos();$("ul.view-type li").removeClass("active");$(this).parent().addClass("active");$("#favoritesSection").hide();$("ul#makes li span.fav").hide();$("#makesSection .view").removeClass("tiles").addClass("list");$("ul#makes li").removeClass("tile");calcList();if(save!=false){saveViewTypeToPreferences($(this).attr('class'),$(this).attr('activePage'),$(this).attr('data-save-url'))}});$('.view-type li.active a').trigger('click',[false]);$('#favoritesSection').on('click','.fav',function(e){e.stopPropagation();e.preventDefault();$(this).toggleClass('active');$(this).animate({opacity:0},250);$(this).parent().animate({opacity:0},250,function(){$(this).remove();calcTiles();$('#'+$(this).attr('id').replace(/tile/i,'list')+' .fav').removeClass('active');var url=$('#'+$(this).attr('id').replace(/tile/i,'list')+' .fav').attr("data-url");addRemoveFavorites(url+"&step=remove")})});$('#makesSection').on('click','.fav',function(e){e.stopPropagation();e.preventDefault();var list=$(this).parent(),id=list.attr('id').replace(/^.+_/i,'');if($(this).hasClass('active')){$('#tile_'+id+' .fav').trigger('click')}else{var replacements={id:id,name:list.find('a').text(),url:list.find('a').attr('href'),image:list.find('img').attr('src').replace(/\/big/i,'')},html='<li id="tile_#{id}" class="tile"><div class="fav active"></div><a href="#{url}"><img class="make-logo-big" src="#{image}"/>#{name}</a></li>';html=html.replace(/\#\{([a-z]+)\}/ig,function(str,key){return replacements[key]});$(html).appendTo('.view.tiles ul');calcTiles();$(this).toggleClass('active');var url=$(this).attr("data-url");addRemoveFavorites(url+"&step=add")}return false})});function carsHistory(url,urlModelsDetail,urlWoDetails){if($('#carsHistory ul li').length==0){var urlModelsInitial=urlModelsDetail;var urlWoDetailsInitial=urlWoDetails;$.ajax({type:'GET',url:url,dataType:'json',cache:false,contentType:'application/json',beforeSend:function(){$('#carsHistory').html("<div class='loading'></div>")},success:function(data){$('#carsHistory').empty();if(data!=null&&data.carTypes!=null&&data.carTypes.length>0){var ul=$('<ul></ul>');$.each(data.carTypes,function(i,item){if(i<11){urlModelsDetail=urlModelsInitial+'?typeId='+item.externalCarId;urlWoDetails=urlWoDetailsInitial+'?nrNumber='+data.carTypeIdWithWorkOrderMap[item.id];if(data.carTypeIdWithWorkOrderMap[item.id]!=null)$('<li></li>').html('<a href="'+urlModelsDetail+'">'+item.name+(item.engineCode!=null?' ('+item.engineCode+') ':' ')+dateFormatter.dateInterval(item.madeFrom,item.madeUntil)+'</a><a href="'+urlWoDetails+'">'+orderNumber+data.carTypeIdWithWorkOrderMap[item.id]+'</a>').appendTo(ul);else $('<li></li>').html('<a href="'+urlModelsDetail+'">'+item.name+(item.engineCode!=null?' ('+item.engineCode+') ':' ')+dateFormatter.dateInterval(item.madeFrom,item.madeUntil)+'</a>').appendTo(ul)}});$(ul).appendTo('#carsHistory')}},error:function(qXHR,textStatus,errorThrown){$('#carsHistory').html("<p>"+textStatus+" - "+errorThrown+"</p>")}})}}function prepFavoritesList(){$("ul#makes li span.fav").each(function(i){var list=$(this).parent(),id=list.attr('id').replace(/^.+_/i,'');if($(this).hasClass('active')){var replacements={id:id,name:list.find('a').text(),url:list.find('a').attr('href'),image:list.find('img').attr('src').replace(/\/big/i,'')},html='<li id="tile_#{id}" class="tile"><span class="fav active"></span><a href="#{url}"><img class="make-logo-big" src="#{image}"/>#{name}</a></li>';html=html.replace(/\#\{([a-z]+)\}/ig,function(str,key){return replacements[key]});$(html).appendTo('.view.tiles ul')}})}function addRemoveFavorites(url){$.ajax({type:'POST',url:url})}function switchToBigMakeLogos(){$(".logo-list").attr('class','logo-list make-logo-big')}function switchToListMakeLogos(){$(".logo-list").attr('class','logo-list make-logo-list')}