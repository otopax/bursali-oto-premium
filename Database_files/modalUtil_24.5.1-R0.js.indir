function createModal(contentID,popupStyleClass,title,width,height){$('<div id="overlay" class="overlay"></div>').appendTo('body');if(!isNullOrEmpty(title)){$('<section id="popup"  class="ui-front '+popupStyleClass+'">'+'<div class="top"></div>'+'<nav>'+'<div>'+'<h2 style="display: inline-block; margin-left: 20px;">'+title+'</h2>'+'<a style="display: inline-block;" href="#" class="popup-button-close"></a>'+'</div>'+'</nav>'+'<div id="'+contentID+'"></div>'+'</section>').appendTo('body')}else{$('<section id="popup"  class="ui-front">'+'<div class="top"></div>'+'<nav>'+'<div>'+'<a href="#" class="popup-button-close"></a>'+'</div>'+'</nav>'+'<div id="'+contentID+'"></div>'+'</section>').appendTo('body')}$("#popup").css({"z-index":9999});var $overlay=$('#overlay');$overlay.css({"z-index":2});var $popup=$('#popup');$overlay.click(function(event){event.stopPropagation();$popup.css({opacity:0,display:'none'});$overlay.remove();$popup.remove()});$overlay.height($(document).height());if(isNullOrEmpty(height)){$popup.height("662")}else{$popup.height(height)}if(isNullOrEmpty(width)){$popup.width('1215')}else{$popup.width(width)}if(window.innerWidth<1215){$popup.css({zoom:"0.8"})}var $body=$("body");var popupHeight=$popup.height();if($body.height()<=popupHeight){$body.height(popupHeight+200);$overlay.height($(document).height())}$popup.css({marginLeft:0,top:$(window).scrollTop()+12,transform:'translate(-50%)',display:'block',opacity:1});closeModalHandler()}function closeModalHandler(){$('#popup .popup-button-close').on('click',function(){$('#popup').css({opacity:0,display:'none'});$('#overlay').remove();$('#popup').remove()})}